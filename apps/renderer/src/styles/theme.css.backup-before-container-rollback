}

/* NOXUS BLACK CARDS â€” KEEP SMALL ICON TILES IN THEIR ORIGINAL COLORS */
:root { --noxus-card-black: #0a0a0a; --noxus-card-black-hover: #111111; }
/* Large cards, panels, pages and form containers */
article[class*="bg-"], section[class*="bg-"], aside[class*="bg-"],
article[class*="rounded"], section[class*="rounded"], aside[class*="rounded"],
div[class*="rounded-xl"][class*="border"]:not([class*="h-"]):not([class*="w-"]),
div[class*="rounded-2xl"][class*="border"]:not([class*="h-"]):not([class*="w-"]),
div[class*="rounded-lg"][class*="p-"]:not([class*="h-"]):not([class*="w-"]) {
