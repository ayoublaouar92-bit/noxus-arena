/* Green text for normal positive/status text. Debt/negative values remain red. */
:root { --noxus-green-text: #55f28a; --noxus-green-glow: rgba(40,230,104,.42); }
/* Change ordinary red accent labels, status text, and icons to green */
.text-rose-300:not(.debt):not(.debt *),
.text-rose-400:not(.debt):not(.debt *),
.text-red-300:not(.debt):not(.debt *),
.text-red-400:not(.debt):not(.debt *),
.text-red-500:not(.debt):not(.debt *),
.text-violet-300,
.text-cyan-300,
.text-sky-300,
.text-emerald-300 {
  color: var(--noxus-green-text) !important;
  text-shadow: 0 0 14px var(--noxus-green-glow) !important;
}
/* Preserve warning/debt/error contexts in red */
.debt, .debt *,
[data-debt], [data-debt] *,
[data-negative], [data-negative] *,
.text-destructive,
.text-destructive *,
.text-rose-500[class*="debt"],
.text-red-500[class*="debt"] {
  color: #ff4d6d !important;
  text-shadow: 0 0 14px rgba(255,0,60,.56) !important;
}
/* Positive badges and regular status indicators */
[class*="text-rose"]:not([class*="debt"]):not(.text-destructive) {
  color: var(--noxus-green-text) !important;
  text-shadow: 0 0 14px var(--noxus-green-glow) !important;
}


/* NOXUS TEXT RULES: white by default; red for debts/errors; green for wallet/profit */
:root { --noxus-positive: #55f28a; --noxus-negative: #ff4d6d; }
/* Neutralize decorative color text: normal UI copy stays white */
.text-violet-300,.text-violet-400,.text-violet-500,
.text-cyan-300,.text-cyan-400,.text-cyan-500,
.text-sky-300,.text-sky-400,.text-sky-500,
.text-amber-300,.text-amber-400,.text-amber-500,
.text-blue-300,.text-blue-400,.text-blue-500,
.text-purple-300,.text-purple-400,.text-purple-500 {
  color: #fff !important;
  text-shadow: none !important;
}
/* Debt, errors, destructive values, and negative balances remain red */
.text-rose-300,.text-rose-400,.text-rose-500,
.text-red-300,.text-red-400,.text-red-500,
.text-destructive,.text-destructive *,
.debt,.debt *,[data-debt],[data-debt] *,[data-negative],[data-negative] * {
  color: var(--noxus-negative) !important;
  text-shadow: 0 0 13px rgba(255,0,60,.45) !important;
}
/* Wallet balance, profits, earnings and positive values remain green */
.text-emerald-300,.text-emerald-400,.text-emerald-500,
.text-green-300,.text-green-400,.text-green-500,
.text-lime-300,.text-lime-400,.text-lime-500,
.profit,.profit *,.earnings,.earnings *,.wallet-balance,.wallet-balance *,
[data-profit],[data-profit] *,[data-wallet-balance],[data-wallet-balance] * {
  color: var(--noxus-positive) !important;
  text-shadow: 0 0 13px rgba(40,230,104,.42) !important;
}


/* NOXUS DEEP-BLACK CONTAINERS */
:root {
  --noxus-bg: #030303;
  --noxus-bg-deep: #020202;
  --noxus-surface: #0a0a0a;
  --noxus-surface-2: #0d0d0d;
  --noxus-surface-3: #121212;
}
/* Main shell, side navigation, top bar and content area */
.noxus-shell { background:#030303 !important; }
.noxus-sidebar { background:linear-gradient(180deg,#0c0c0c,#050505) !important; }
.noxus-topbar { background:linear-gradient(90deg,#101010,#080808) !important; }
.noxus-main { background:#050505 !important; }
/* Cards, panels, tables, dialogs and containers that hold text/icons */
article[class*="rounded"],section[class*="rounded"],aside[class*="rounded"],
div[class*="rounded-xl"][class*="border"],div[class*="rounded-2xl"][class*="border"],
[class*="bg-[#0c101d]"],[class*="bg-[#0b0f1c]"],[class*="bg-[#090d18]"],
[class*="bg-[#080b16]"],[class*="bg-[#050711]"],[class*="bg-[#070a14]"] {
