@import "tailwindcss";
@import "tw-animate-css";
@import "shadcn/tailwind.css";
@import "@fontsource-variable/geist";

@custom-variant dark (&:is(.dark *));

:root {
  --noxus-bg: #07070b;
  --noxus-surface: #12121a;
  --noxus-purple: #8b5cf6;
  --noxus-neon: #c084fc;
  --noxus-blue: #38bdf8;
  --background: oklch(1 0 0);
  --foreground: oklch(0.145 0 0);
  --card: oklch(1 0 0);
  --card-foreground: oklch(0.145 0 0);
  --popover: oklch(1 0 0);
  --popover-foreground: oklch(0.145 0 0);
  --primary: oklch(0.205 0 0);
  --primary-foreground: oklch(0.985 0 0);
  --secondary: oklch(0.97 0 0);
  --secondary-foreground: oklch(0.205 0 0);
  --muted: oklch(0.97 0 0);
  --muted-foreground: oklch(0.556 0 0);
  --accent: oklch(0.97 0 0);
  --accent-foreground: oklch(0.205 0 0);
  --destructive: oklch(0.577 0.245 27.325);
  --border: oklch(0.922 0 0);
  --input: oklch(0.922 0 0);
  --ring: oklch(0.708 0 0);
  --chart-1: oklch(0.87 0 0);
  --chart-2: oklch(0.556 0 0);
  --chart-3: oklch(0.439 0 0);
  --chart-4: oklch(0.371 0 0);
  --chart-5: oklch(0.269 0 0);
  --radius: 0.625rem;
  --sidebar: oklch(0.985 0 0);
  --sidebar-foreground: oklch(0.145 0 0);
  --sidebar-primary: oklch(0.205 0 0);
  --sidebar-primary-foreground: oklch(0.985 0 0);
  --sidebar-accent: oklch(0.97 0 0);
  --sidebar-accent-foreground: oklch(0.205 0 0);
  --sidebar-border: oklch(0.922 0 0);
  --sidebar-ring: oklch(0.708 0 0);
}

body {
  margin: 0;
  background: var(--noxus-bg);
  color: white;
  font-family: Inter, system-ui, sans-serif;
}

@theme inline {
  --font-heading: var(--font-sans);
  --font-sans: "Geist Variable", sans-serif;
  --color-sidebar-ring: var(--sidebar-ring);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar: var(--sidebar);
  --color-chart-5: var(--chart-5);
  --color-chart-4: var(--chart-4);
  --color-chart-3: var(--chart-3);
  --color-chart-2: var(--chart-2);
  --color-chart-1: var(--chart-1);
  --color-ring: var(--ring);
  --color-input: var(--input);
  --color-border: var(--border);
  --color-destructive: var(--destructive);
  --color-accent-foreground: var(--accent-foreground);
  --color-accent: var(--accent);
  --color-muted-foreground: var(--muted-foreground);
  --color-muted: var(--muted);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-secondary: var(--secondary);
  --color-primary-foreground: var(--primary-foreground);
  --color-primary: var(--primary);
  --color-popover-foreground: var(--popover-foreground);
  --color-popover: var(--popover);
  --color-card-foreground: var(--card-foreground);
  --color-card: var(--card);
  --color-foreground: var(--foreground);
  --color-background: var(--background);
  --radius-sm: calc(var(--radius) * 0.6);
  --radius-md: calc(var(--radius) * 0.8);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) * 1.4);
  --radius-2xl: calc(var(--radius) * 1.8);
  --radius-3xl: calc(var(--radius) * 2.2);
  --radius-4xl: calc(var(--radius) * 2.6);
}

.dark {
  --background: oklch(0.145 0 0);
  --foreground: oklch(0.985 0 0);
  --card: oklch(0.205 0 0);
  --card-foreground: oklch(0.985 0 0);
  --popover: oklch(0.205 0 0);
  --popover-foreground: oklch(0.985 0 0);
  --primary: oklch(0.922 0 0);
  --primary-foreground: oklch(0.205 0 0);
  --secondary: oklch(0.269 0 0);
  --secondary-foreground: oklch(0.985 0 0);
  --muted: oklch(0.269 0 0);
  --muted-foreground: oklch(0.708 0 0);
  --accent: oklch(0.269 0 0);
  --accent-foreground: oklch(0.985 0 0);
  --destructive: oklch(0.704 0.191 22.216);
  --border: oklch(1 0 0 / 10%);
  --input: oklch(1 0 0 / 15%);
  --ring: oklch(0.556 0 0);
  --chart-1: oklch(0.87 0 0);
  --chart-2: oklch(0.556 0 0);
  --chart-3: oklch(0.439 0 0);
  --chart-4: oklch(0.371 0 0);
  --chart-5: oklch(0.269 0 0);
  --sidebar: oklch(0.205 0 0);
  --sidebar-foreground: oklch(0.985 0 0);
  --sidebar-primary: oklch(0.488 0.243 264.376);
  --sidebar-primary-foreground: oklch(0.985 0 0);
  --sidebar-accent: oklch(0.269 0 0);
  --sidebar-accent-foreground: oklch(0.985 0 0);
  --sidebar-border: oklch(1 0 0 / 10%);
  --sidebar-ring: oklch(0.556 0 0);
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  body {
    @apply bg-background text-foreground;
  }
  html {
    @apply font-sans;
  }
}

/* Noxus Spectrum Arena UI */
:root {
  --noxus-bg: #13152a;
  --noxus-bg-deep: #0f1122;
  --noxus-surface: #1c203b;
  --noxus-surface-2: #242846;
  --noxus-surface-3: #2b3051;
  --noxus-purple: #7c5cff;
  --noxus-violet: #9b6cff;
  --noxus-blue: #2d8cff;
  --noxus-cyan: #20d8ff;
  --noxus-green: #20e6ad;
  --noxus-yellow: #ffd166;
  --noxus-red: #ff5c8a;
  --noxus-line: rgba(159, 168, 255, 0.14);
  --noxus-text-soft: rgba(231, 235, 255, 0.62);
  color-scheme: dark;
}

html {
  background: var(--noxus-bg-deep);
}

body {
  min-width: 1040px;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(
      circle at 18% 8%,
      rgba(124, 92, 255, 0.22),
      transparent 30%
    ),
    radial-gradient(
      circle at 82% 12%,
      rgba(32, 216, 255, 0.13),
      transparent 29%
    ),
    radial-gradient(
      circle at 68% 92%,
      rgba(32, 230, 173, 0.08),
      transparent 30%
    ),
    linear-gradient(145deg, #12142a 0%, #17192f 48%, #101226 100%) !important;
  color: #f6f7ff;
  font-family: "Geist Variable", Inter, system-ui, sans-serif;
}

::selection {
  background: rgba(124, 92, 255, 0.55);
  color: white;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.36;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.018) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
  background-size: 38px 38px;
  mask-image: radial-gradient(circle at 55% 20%, black, transparent 82%);
}

.noxus-shell {
  isolation: isolate;
  background:
    radial-gradient(circle at 88% 4%, rgba(45, 140, 255, 0.1), transparent 26%),
    linear-gradient(135deg, rgba(19, 21, 42, 0.98), rgba(15, 17, 34, 0.98)) !important;
}

.noxus-shell::after {
  content: "";
  position: absolute;
  inset: auto 8% -260px auto;
  width: 560px;
  height: 560px;
  border-radius: 999px;
  pointer-events: none;
  background: rgba(124, 92, 255, 0.08);
  filter: blur(110px);
  animation: noxusOrb 10s ease-in-out infinite alternate;
}

.noxus-sidebar {
  width: 252px;
  border-color: rgba(144, 153, 255, 0.12) !important;
  background: linear-gradient(
    180deg,
    rgba(24, 27, 52, 0.98),
    rgba(15, 17, 34, 0.98)
  ) !important;
  box-shadow:
    18px 0 48px rgba(3, 5, 18, 0.28),
    inset -1px 0 rgba(255, 255, 255, 0.025);
}

.noxus-sidebar nav a {
  border: 1px solid transparent;
  transform-origin: left center;
}

.noxus-sidebar nav a:hover {
  border-color: rgba(118, 143, 255, 0.12);
  background: linear-gradient(
    90deg,
    rgba(124, 92, 255, 0.12),
    rgba(45, 140, 255, 0.055)
  ) !important;
}

.noxus-sidebar nav a[aria-current="page"] {
  border-color: rgba(176, 147, 255, 0.22);
  background: linear-gradient(
    90deg,
    #6847e8 0%,
    rgba(89, 77, 214, 0.72) 58%,
    rgba(45, 140, 255, 0.28) 100%
  ) !important;
  box-shadow:
    0 10px 30px rgba(82, 54, 205, 0.28),
    inset 0 1px rgba(255, 255, 255, 0.13);
}

.noxus-topbar {
  border-color: rgba(144, 153, 255, 0.12) !important;
  background: linear-gradient(
    90deg,
    rgba(25, 28, 54, 0.92),
    rgba(19, 22, 44, 0.86)
  ) !important;
  box-shadow:
    0 14px 34px rgba(4, 6, 20, 0.2),
    inset 0 -1px rgba(255, 255, 255, 0.02);
}

.noxus-main {
  position: relative;
  scroll-behavior: smooth;
  background: linear-gradient(
    145deg,
    rgba(27, 30, 56, 0.4),
    rgba(14, 16, 33, 0.18)
  );
}

.noxus-main > div {
  animation: noxusPageIn 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.noxus-main > div > section,
.noxus-main > div > article {
  animation: noxusSectionIn 540ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}
.noxus-main > div > :nth-child(2) {
  animation-delay: 45ms;
}
.noxus-main > div > :nth-child(3) {
  animation-delay: 90ms;
}
.noxus-main > div > :nth-child(4) {
  animation-delay: 135ms;
}
.noxus-main > div > :nth-child(5) {
  animation-delay: 180ms;
}
.noxus-main > div > :nth-child(6) {
  animation-delay: 225ms;
}

[class*="bg-[#050711]"],
[class*="bg-[#070a14]"] {
  background-color: var(--noxus-bg-deep) !important;
}

[class*="bg-[#0c101d]"],
[class*="bg-[#0b0f1c]"] {
  background: linear-gradient(
    145deg,
    rgba(36, 40, 70, 0.96),
    rgba(25, 29, 54, 0.96)
  ) !important;
}

[class*="bg-[#090d18]"] {
  background: linear-gradient(
    145deg,
    rgba(31, 35, 63, 0.97),
    rgba(23, 26, 49, 0.97)
  ) !important;
}

[class*="bg-[#080b16]"] {
  background: rgba(17, 20, 40, 0.86) !important;
}

[class*="border-white/[0.08]"],
[class*="border-white/[0.07]"],
[class*="border-white/[0.06]"] {
  border-color: var(--noxus-line) !important;
}

article[class*="rounded-xl"],
section[class*="rounded-xl"],
aside[class*="rounded-xl"],
div[class*="rounded-xl"][class*="border"] {
  box-shadow:
    inset 0 1px rgba(255, 255, 255, 0.055),
    0 18px 45px rgba(3, 5, 18, 0.2);
}

article[class*="rounded-xl"],
section[class*="rounded-xl"],
div[class*="rounded-xl"][class*="border"] {
  transition:
    transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1),
    border-color 240ms ease,
    box-shadow 240ms ease,
    filter 240ms ease;
}

article[class*="rounded-xl"]:hover,
div[class*="rounded-xl"][class*="border"]:hover {
  border-color: rgba(125, 113, 255, 0.28) !important;
  box-shadow:
    inset 0 1px rgba(255, 255, 255, 0.075),
    0 22px 52px rgba(4, 6, 22, 0.3),
    0 0 0 1px rgba(124, 92, 255, 0.035);
}

.noxus-stat-card {
  overflow: hidden;
  position: relative;
  min-height: 138px;
}
.noxus-stat-card::after {
  content: "";
  position: absolute;
  width: 150px;
  height: 150px;
  left: -70px;
  bottom: -95px;
  border-radius: 999px;
  filter: blur(18px);
  opacity: 0.24;
  background: var(--stat-glow, #7c5cff);
  transition:
    transform 350ms ease,
    opacity 350ms ease;
}
.noxus-stat-card:nth-child(1) {
  --stat-glow: #7c5cff;
}
.noxus-stat-card:nth-child(2) {
  --stat-glow: #20e6ad;
}
.noxus-stat-card:nth-child(3) {
  --stat-glow: #20d8ff;
}
.noxus-stat-card:nth-child(4) {
  --stat-glow: #ffd166;
}
.noxus-stat-card:hover {
  transform: translateY(-5px);
}
.noxus-stat-card:hover::after {
  transform: scale(1.25);
  opacity: 0.38;
}

.noxus-hero {
  border-color: rgba(124, 92, 255, 0.25) !important;
  background:
    radial-gradient(
      circle at 78% 32%,
      rgba(32, 216, 255, 0.14),
      transparent 28%
    ),
    radial-gradient(
      circle at 14% 76%,
      rgba(124, 92, 255, 0.26),
      transparent 35%
    ),
    linear-gradient(135deg, #25284a 0%, #1e2140 55%, #182039 100%) !important;
  box-shadow:
    0 28px 70px rgba(5, 7, 24, 0.34),
    inset 0 1px rgba(255, 255, 255, 0.08) !important;
}

input,
select,
textarea {
  border-color: rgba(144, 153, 255, 0.14) !important;
  background: rgba(15, 18, 38, 0.84) !important;
  color: #f5f6ff !important;
  box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.16);
}
input::placeholder,
textarea::placeholder {
  color: rgba(218, 223, 255, 0.28) !important;
}
input:focus,
select:focus,
textarea:focus {
  border-color: rgba(32, 216, 255, 0.5) !important;
  box-shadow:
    0 0 0 4px rgba(32, 216, 255, 0.085),
    inset 0 1px 2px rgba(0, 0, 0, 0.12) !important;
}

button,
a,
input,
select,
textarea {
  transition:
    transform 180ms ease,
    border-color 180ms ease,
    background-color 180ms ease,
    color 180ms ease,
    box-shadow 180ms ease,
    opacity 180ms ease,
    filter 180ms ease;
}
button:not(:disabled):hover,
a[href]:hover {
  transform: translateY(-2px);
}
button:not(:disabled):active,
a[href]:active {
  transform: translateY(0) scale(0.975);
}
button:disabled {
  cursor: not-allowed;
}

button[class*="bg-violet-600"],
button[class*="bg-violet-500"] {
  background: linear-gradient(100deg, #6b4deb, #875cf5 55%, #597bff) !important;
  box-shadow:
    0 10px 30px rgba(105, 76, 232, 0.26),
    inset 0 1px rgba(255, 255, 255, 0.18);
}
button[class*="bg-emerald"] {
  background: linear-gradient(
    100deg,
    rgba(20, 178, 142, 0.9),
    rgba(32, 230, 173, 0.78)
  ) !important;
  box-shadow:
    0 10px 28px rgba(32, 230, 173, 0.16),
    inset 0 1px rgba(255, 255, 255, 0.14);
}
button[class*="bg-rose"] {
  box-shadow: 0 10px 25px rgba(255, 92, 138, 0.12);
}

button[class*="bg-violet"],
button[class*="bg-emerald"],
button[class*="bg-rose"],
button[class*="bg-amber"] {
  position: relative;
  overflow: hidden;
}
button[class*="bg-violet"]::after,
button[class*="bg-emerald"]::after,
button[class*="bg-rose"]::after,
button[class*="bg-amber"]::after {
  content: "";
  position: absolute;
  top: -80%;
  bottom: -80%;
  left: -60%;
  width: 38%;
  pointer-events: none;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.24),
    transparent
  );
  transform: skewX(-18deg);
}
button[class*="bg-violet"]:hover::after,
button[class*="bg-emerald"]:hover::after,
button[class*="bg-rose"]:hover::after,
button[class*="bg-amber"]:hover::after {
  animation: noxusShine 760ms ease;
}

.text-violet-300,
.text-cyan-300,
.text-sky-300,
.text-emerald-300,
.text-amber-300,
.text-rose-300 {
  text-shadow: 0 0 18px color-mix(in srgb, currentColor 42%, transparent);
}

svg {
  transition:
    transform 200ms ease,
    filter 200ms ease,
    color 200ms ease;
}
a:hover svg,
button:hover svg {
  transform: translateY(-1px) scale(1.08);
  filter: drop-shadow(0 0 7px currentColor);
}

tr {
  transition:
    background-color 170ms ease,
    transform 170ms ease;
}
tbody tr:hover {
  background: rgba(124, 92, 255, 0.055);
}

.fixed.inset-0[class*="bg-black"] {
  animation: noxusBackdropIn 180ms ease both;
}
.fixed.inset-0[class*="bg-black"] > * {
  animation: noxusModalIn 260ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.absolute.h-1\\.5.w-1\\.5,
.absolute.h-2\\.5.w-2\\.5 {
  animation: noxusPulse 1.8s ease-in-out infinite;
}

@keyframes noxusPageIn {
  from {
    opacity: 0;
    transform: translateY(14px) scale(0.995);
    filter: blur(4px);
  }
  to {
    opacity: 1;
    transform: none;
    filter: none;
  }
}
@keyframes noxusSectionIn {
  from {
    opacity: 0;
    transform: translateY(18px);
  }
  to {
    opacity: 1;
    transform: none;
  }
}
@keyframes noxusModalIn {
  from {
    opacity: 0;
    transform: translateY(12px) scale(0.96);
  }
  to {
    opacity: 1;
    transform: none;
  }
}
@keyframes noxusBackdropIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
@keyframes noxusPulse {
  0%,
  100% {
    opacity: 0.68;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.18);
  }
}
@keyframes noxusShine {
  from {
    left: -60%;
  }
  to {
    left: 135%;
  }
}
@keyframes noxusOrb {
  from {
    transform: translate3d(0, 0, 0) scale(1);
  }
  to {
    transform: translate3d(-70px, -30px, 0) scale(1.14);
  }
}

::-webkit-scrollbar {
  width: 9px;
  height: 9px;
}
::-webkit-scrollbar-track {
  background: rgba(10, 12, 28, 0.55);
}
::-webkit-scrollbar-thumb {
  border: 2px solid rgba(12, 14, 31, 0.92);
  border-radius: 999px;
  background: linear-gradient(180deg, #7658ee, #2d8cff 55%, #20d8ff);
}
::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, #9b6cff, #20d8ff);
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
    scroll-behavior: auto !important;
  }
}

