/* NOXUS RED / BLACK / WHITE ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â FINAL INTERACTIVE THEME */
:root {
  --noxus-bg: #050505;
  --noxus-bg-deep: #020202;
  --noxus-surface: #101010;
  --noxus-surface-2: #171717;
  --noxus-surface-3: #202020;
  --noxus-purple: #ff003c;
  --noxus-violet: #ff174d;
  --noxus-blue: #ff4d6d;
  --noxus-cyan: #ff6b35;
  --noxus-green: #ff4d6d;
  --noxus-red: #ff003c;
  --noxus-line: rgba(255,255,255,.10);
  --noxus-text-soft: rgba(255,255,255,.78);
  color-scheme: dark;
}
html, body { background: #050505 !important; }
html[dir="rtl"], html[dir="rtl"] body {
  font-family: "Cairo", "Noto Sans Arabic", "Segoe UI", Tahoma, sans-serif !important;
}
body {
  color: #fff !important;
  background:
    radial-gradient(circle at 18% 8%, rgba(255,0,60,.20), transparent 31%),
    radial-gradient(circle at 82% 14%, rgba(144,0,32,.15), transparent 29%),
    linear-gradient(145deg,#030303 0%,#0b0305 48%,#050505 100%) !important;
}
::selection { background:#ff003c; color:#fff; }
.noxus-shell { background: linear-gradient(135deg,rgba(10,10,10,.98),rgba(3,3,3,.98)) !important; }
.noxus-shell::after { background:rgba(255,0,60,.10) !important; }
.noxus-sidebar { background:linear-gradient(180deg,rgba(17,17,17,.99),rgba(5,5,5,.99)) !important; border-color:rgba(255,255,255,.09) !important; }
.noxus-topbar { background:linear-gradient(90deg,rgba(20,20,20,.96),rgba(8,8,8,.92)) !important; border-color:rgba(255,255,255,.09) !important; }
.noxus-main { background:linear-gradient(145deg,rgba(24,8,11,.20),rgba(5,5,5,.10)) !important; }
.noxus-sidebar nav a:hover { background:linear-gradient(90deg,rgba(255,0,60,.20),rgba(255,0,60,.04)) !important; border-color:rgba(255,0,60,.36) !important; }
.noxus-sidebar nav a[aria-current="page"] { background:linear-gradient(90deg,#cb0030 0%,rgba(177,0,38,.78) 60%,rgba(96,0,20,.42) 100%) !important; border-color:rgba(255,64,96,.65) !important; box-shadow:0 10px 30px rgba(255,0,60,.32),inset 0 1px rgba(255,255,255,.18) !important; }
[class*="bg-[#0c101d]"],[class*="bg-[#0b0f1c]"],[class*="bg-[#090d18]"] { background:linear-gradient(145deg,#191919,#0d0d0d) !important; }
[class*="bg-[#050711]"],[class*="bg-[#070a14]"],[class*="bg-[#080b16]"] { background-color:#080808 !important; }
article[class*="rounded-xl"],section[class*="rounded-xl"],div[class*="rounded-xl"][class*="border"] { box-shadow:inset 0 1px rgba(255,255,255,.05),0 18px 45px rgba(0,0,0,.34) !important; }
article[class*="rounded-xl"]:hover,div[class*="rounded-xl"][class*="border"]:hover { border-color:rgba(255,0,60,.34) !important; box-shadow:inset 0 1px rgba(255,255,255,.07),0 22px 52px rgba(0,0,0,.42),0 0 22px rgba(255,0,60,.07) !important; }
input,select,textarea { background:#0c0c0c !important; color:#fff !important; border-color:rgba(255,255,255,.14) !important; }
input:focus,select:focus,textarea:focus { border-color:rgba(255,0,60,.72) !important; box-shadow:0 0 0 4px rgba(255,0,60,.12) !important; }
button[class*="bg-violet"],button[class*="bg-emerald"],button[class*="bg-rose"] { background:linear-gradient(100deg,#b9002d,#ff003c 55%,#8d001f) !important; color:#fff !important; box-shadow:0 10px 28px rgba(255,0,60,.30),inset 0 1px rgba(255,255,255,.18) !important; }
.text-violet-300,.text-cyan-300,.text-sky-300,.text-emerald-300,.text-amber-300,.text-rose-300 { color:#ff7890 !important; text-shadow:0 0 16px rgba(255,0,60,.58) !important; }
/* Fire embers appear only while hovering an icon/button */
.noxus-sidebar nav a,.noxus-topbar button,button { position:relative; isolation:isolate; }
.noxus-sidebar nav a:hover svg,.noxus-topbar button:hover svg,button:hover svg { transform:translateY(-1px) scale(1.13) rotate(-4deg); color:#fff !important; filter:drop-shadow(0 0 5px #ff6a00) drop-shadow(0 0 13px #ff003c) !important; }
.noxus-sidebar nav a:hover::after,.noxus-topbar button:hover::after,button:hover::after { content:""; position:absolute; pointer-events:none; z-index:4; width:8px; height:15px; left:32%; top:-5px; border-radius:70% 30% 65% 35%; background:radial-gradient(circle at 48% 72%,#fff6a6 0 11%,#ffc229 15% 29%,#ff7200 34% 59%,#e60035 66% 100%); filter:drop-shadow(0 0 5px #ff7a00) drop-shadow(0 0 11px #ff003c); box-shadow:18px 11px 0 -2px #ff6b00,-13px 17px 0 -3px #ffcb39,30px 24px 0 -4px #e60035,-23px 28px 0 -4px #ff7800; animation:noxusFireEmbers .68s ease-out both; }
@keyframes noxusFireEmbers { 0% { opacity:0; transform:translate(0,10px) scale(.42) rotate(-20deg); } 35% { opacity:1; } 100% { opacity:0; transform:translate(17px,-30px) scale(1.1) rotate(26deg); } }
::-webkit-scrollbar-track { background:#090909; }
