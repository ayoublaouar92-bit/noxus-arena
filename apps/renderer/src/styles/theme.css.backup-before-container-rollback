  background-image: none !important;
  border-color: rgba(255,255,255,.11) !important;
}
/* Inventory/product banner rectangles are cards too: black them without touching icon tiles */
div[class*="h-24"][class*="bg-gradient"],
div[class*="h-28"][class*="bg-gradient"],
div[class*="h-32"][class*="bg-gradient"] {
