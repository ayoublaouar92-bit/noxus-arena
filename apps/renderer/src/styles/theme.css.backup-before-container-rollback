  background-image:none !important;
  border-color:rgba(255,255,255,.10) !important;
  box-shadow:inset 0 1px rgba(255,255,255,.045),0 16px 34px rgba(0,0,0,.42) !important;
}
/* Inputs and dropdown containers */
input,select,textarea,[role="dialog"],[role="menu"] {
  background:#0b0b0b !important;
  border-color:rgba(255,255,255,.13) !important;
}
/* Hover retains black; only a thin red edge is shown */
article[class*="rounded"]:hover,section[class*="rounded"]:hover,div[class*="rounded-xl"][class*="border"]:hover {
  background:#141414 !important;
  border-color:rgba(255,0,60,.42) !important;
