import {
  Activity,
  ArrowUpRight,
  Banknote,
  Clock3,
  Gamepad2,
  Monitor,
  RefreshCw,
  Timer,
  Users,
  Wrench,
} from "lucide-react";
import { useEffect, useMemo, useState } from "react";
import { Link } from "react-router-dom";
import { useLanguage } from "../lib/i18n";

type Device = { id: number; name: string; type: string; price: string; status: "Available" | "Busy" };
type Session = { id: number; deviceId: number; deviceName: string; customerName: string; startTime: string; hourlyPrice: string; status: string };

export default function Dashboard() {
  const { dir, language, locale } = useLanguage();
  const tr = (en: string, ar: string, fr: string) => language === "ar" ? ar : language === "fr" ? fr : en;
  const [devices, setDevices] = useState<Device[]>([]);
  const [sessions, setSessions] = useState<Session[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");
  const [, setNow] = useState(Date.now());
  const api = (window as any).api;

  async function loadDashboard(showLoading = false) {
    try {
      if (showLoading) setLoading(true);
      setError("");
      const [devicesResult, sessionsResult] = await Promise.all([api.getDevices(), api.getActiveSessions()]);
      setDevices(devicesResult);
      setSessions(sessionsResult);
    } catch (loadError) {
      console.error(loadError);
      setError(tr("Dashboard failed to load", "تعذر تحميل لوحة التحكم", "Impossible de charger le tableau de bord"));
    } finally { setLoading(false); }
  }

  useEffect(() => {
    void loadDashboard(true);
    const clock = window.setInterval(() => setNow(Date.now()), 1000);
    const refresh = window.setInterval(() => void loadDashboard(), 5000);
    return () => { window.clearInterval(clock); window.clearInterval(refresh); };
  }, []);

  const minutes = (startTime: string) => Math.max(1, Math.ceil((Date.now() - new Date(startTime).getTime()) / 60000));
  const amount = (session: Session) => ((minutes(session.startTime) / 60) * Number(session.hourlyPrice || 0)).toFixed(2);
  const time = (value: string) => new Date(value).toLocaleTimeString(locale, { hour: "2-digit", minute: "2-digit" });
  const available = useMemo(() => devices.filter((device) => device.status === "Available"), [devices]);
  const busy = useMemo(() => devices.filter((device) => device.status === "Busy"), [devices]);
  const revenue = sessions.reduce((total, session) => total + Number(amount(session)), 0);
  const average = sessions.length ? Math.round(sessions.reduce((total, session) => total + minutes(session.startTime), 0) / sessions.length) : 0;
  const occupancy = devices.length ? Math.round((busy.length / devices.length) * 100) : 0;

  const stats = [
    { label: tr("Active Sessions", "الجلسات النشطة", "Sessions actives"), value: sessions.length, icon: Gamepad2, tone: "red", note: tr("Live right now", "مباشرة الآن", "En direct") },
    { label: tr("Available Devices", "الأجهزة المتاحة", "Appareils disponibles"), value: available.length, icon: Monitor, tone: "purple", note: `${busy.length} ${tr("in use", "مشغولة", "occupés")}` },
    { label: tr("Busy Devices", "الأجهزة المشغولة", "Appareils occupés"), value: busy.length, icon: Users, tone: "blue", note: `${occupancy}% ${tr("occupancy", "إشغال", "occupation")}` },
    { label: tr("Today’s Revenue", "إيراد اليوم", "Revenus du jour"), value: `${revenue.toFixed(2)} DA`, icon: Banknote, tone: "red", note: tr("From active sessions", "من الجلسات النشطة", "Sessions actives") },
  ];

  const quick = [
    { title: tr("Add Session", "بدء جلسة", "Ajouter une session"), description: tr("Start a new session", "بدء جلسة جديدة", "Démarrer une session"), icon: Gamepad2, path: "/sessions", tone: "red" },
    { title: tr("Add Member", "إضافة عضو", "Ajouter un membre"), description: tr("Register a new member", "تسجيل عضو جديد", "Enregistrer un membre"), icon: Users, path: "/members", tone: "purple" },
    { title: tr("Open Cashier", "فتح الكاشير", "Ouvrir la caisse"), description: tr("Open POS system", "فتح نظام البيع", "Ouvrir le POS"), icon: Banknote, path: "/store", tone: "blue" },
    { title: tr("Manage Devices", "إدارة الأجهزة", "Gérer les appareils"), description: tr("View stations", "عرض المحطات", "Voir les postes"), icon: Monitor, path: "/devices", tone: "gold" },
  ];

  return (
    <div dir={dir} className="noxus-dashboard-reference mx-auto max-w-[1460px] space-y-4 pb-5">
      <header className="flex flex-col gap-3 border-b border-white/[0.07] pb-4 lg:flex-row lg:items-center lg:justify-between">
        <div className="flex items-baseline gap-4">
          <h1 className="text-2xl font-semibold tracking-tight">{tr("Dashboard", "لوحة التحكم", "Tableau de bord")}</h1>
          <p className="text-xs text-white/55">{tr("Live arena overview", "نظرة مباشرة على القاعة", "Vue de l’arène en direct")}</p>
        </div>
        <button type="button" onClick={() => void loadDashboard(true)} disabled={loading} className="inline-flex h-9 items-center justify-center gap-2 self-start rounded-md border border-white/[0.10] bg-white/[0.025] px-3 text-xs text-white/80 transition hover:bg-white/[0.06] disabled:opacity-50 lg:self-auto">
          <RefreshCw size={14} className={loading ? "animate-spin" : ""} />
          {tr("Refresh", "تحديث", "Actualiser")}
        </button>
      </header>

      {error && <div className="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">{error}</div>}

      <section className="grid gap-3 sm:grid-cols-2 2xl:grid-cols-4">
        {stats.map((stat) => {
          const Icon = stat.icon;
          return <article key={stat.label} className={`dashboard-stat dashboard-stat-${stat.tone} relative overflow-hidden rounded-lg border border-white/[0.08] p-4`}>
            <Icon className="dashboard-stat-icon absolute right-4 top-4" size={42} strokeWidth={1.5} />
            <p className="text-2xl font-semibold tracking-tight">{stat.value}</p>
            <p className="mt-1 text-xs text-white/80">{stat.label}</p>
            <p className="mt-3 text-[10px] text-emerald-300">● {stat.note}</p>
          </article>;
        })}
      </section>

      <section className="grid gap-4 2xl:grid-cols-[minmax(0,1.42fr)_minmax(300px,.72fr)_minmax(280px,.78fr)]">
        <article className="dashboard-panel overflow-hidden rounded-lg border border-white/[0.08]">
          <div className="flex items-center justify-between border-b border-white/[0.07] px-4 py-3">
            <h2 className="text-sm font-semibold">{tr("Recent Sessions", "الجلسات الأخيرة", "Sessions récentes")}</h2>
            <Link to="/sessions" className="text-[10px] text-white/70 hover:text-white">{tr("View All", "عرض الكل", "Voir tout")}</Link>
          </div>
          <div className="overflow-x-auto"><table className="w-full min-w-[530px] text-left text-[11px]" dir="ltr"><thead className="text-white/55"><tr className="border-b border-white/[0.06]"><th className="px-4 py-2 font-medium">{tr("User", "اللاعب", "Utilisateur")}</th><th className="px-3 py-2 font-medium">{tr("Device", "الجهاز", "Appareil")}</th><th className="px-3 py-2 font-medium">{tr("Start", "البدء", "Début")}</th><th className="px-3 py-2 font-medium">{tr("Duration", "المدة", "Durée")}</th><th className="px-3 py-2 font-medium">{tr("Amount", "المبلغ", "Montant")}</th><th className="px-3 py-2 font-medium">{tr("Status", "الحالة", "Statut")}</th></tr></thead>
            <tbody>{sessions.length === 0 ? <tr><td colSpan={6} className="px-4 py-12 text-center text-white/65">{tr("No active sessions", "لا توجد جلسات نشطة", "Aucune session active")}</td></tr> : sessions.slice(0, 5).map((session) => <tr key={session.id} className="border-b border-white/[0.045] last:border-0"><td className="px-4 py-2.5 font-medium">{session.customerName}</td><td className="px-3 py-2.5">{session.deviceName}</td><td className="px-3 py-2.5 text-white/75">{time(session.startTime)}</td><td className="px-3 py-2.5 text-white/75">{minutes(session.startTime)}m</td><td className="px-3 py-2.5 text-emerald-300">{amount(session)} DA</td><td className="px-3 py-2.5"><span className="rounded-full bg-emerald-500/10 px-2 py-1 text-[9px] text-emerald-300">● {tr("Active", "نشطة", "Active")}</span></td></tr>)}</tbody>
          </table></div>
        </article>

        <article className="dashboard-panel rounded-lg border border-white/[0.08] p-4">
          <div className="flex items-center justify-between"><h2 className="text-sm font-semibold">{tr("Revenue Overview", "نظرة الإيرادات", "Vue des revenus")}</h2><span className="rounded bg-white/[0.04] px-2 py-1 text-[9px] text-white/70">{tr("This Week", "هذا الأسبوع", "Cette semaine")}</span></div>
          <p className="mt-4 text-2xl font-semibold">{revenue.toFixed(2)} DA</p><p className="mt-1 text-[10px] text-emerald-300">↑ {tr("Active session estimate", "تقدير الجلسات النشطة", "Estimation en direct")}</p>
          <div className="mt-5 h-32"><svg viewBox="0 0 300 120" className="h-full w-full overflow-visible"><defs><linearGradient id="revenueFill" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stopColor="#ef233c" stopOpacity=".35"/><stop offset="100%" stopColor="#ef233c" stopOpacity="0"/></linearGradient></defs><path d="M0 95 L25 78 L48 56 L72 75 L95 69 L120 88 L145 48 L168 62 L194 53 L218 77 L243 60 L268 43 L300 17 L300 120 L0 120 Z" fill="url(#revenueFill)"/><path d="M0 95 L25 78 L48 56 L72 75 L95 69 L120 88 L145 48 L168 62 L194 53 L218 77 L243 60 L268 43 L300 17" fill="none" stroke="#ef233c" strokeWidth="2"/></svg></div>
          <div className="flex justify-between text-[9px] text-white/55"><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span></div>
        </article>

        <article className="dashboard-panel rounded-lg border border-white/[0.08]">
          <div className="flex items-center justify-between border-b border-white/[0.07] px-4 py-3"><h2 className="text-sm font-semibold">{tr("Device Status", "حالة الأجهزة", "حالة الأجهزة")}</h2><Link to="/devices" className="text-[10px] text-white/70 hover:text-white">{tr("View All", "عرض الكل", "Voir tout")}</Link></div>
          <div className="space-y-2 p-3">{devices.slice(0,5).map((device) => { const free = device.status === "Available"; return <div key={device.id} className="flex items-center gap-2 rounded-md border border-white/[0.05] bg-white/[0.018] p-2.5"><div className={`flex h-7 w-7 items-center justify-center rounded ${free ? "bg-emerald-500/10 text-emerald-300" : "bg-red-500/10 text-red-300"}`}>{device.type === "PC" ? <Monitor size={14}/> : <Gamepad2 size={14}/>}</div><div className="min-w-0 flex-1"><p className="truncate text-[11px] font-medium">{device.name}</p><p className="text-[9px] text-white/60">{device.type}</p></div><span className={free ? "text-[9px] text-emerald-300" : "text-[9px] text-red-300"}>{free ? tr("Available", "متاح", "Disponible") : tr("In use", "مشغول", "Occupé")}</span></div>})}</div>
        </article>
      </section>

      <section className="grid gap-3 sm:grid-cols-2 2xl:grid-cols-4">{quick.map((item) => { const Icon = item.icon; return <Link key={item.path} to={item.path} className={`dashboard-quick dashboard-quick-${item.tone} flex items-center gap-3 rounded-lg border border-white/[0.08] p-3 transition hover:bg-white/[0.04]`}><div className="flex h-9 w-9 items-center justify-center rounded-md"><Icon size={18}/></div><div><p className="text-xs font-medium">{item.title}</p><p className="mt-1 text-[10px] text-white/65">{item.description}</p></div><ArrowUpRight size={15} className="ml-auto text-white/60"/></Link>; })}</section>

      <section className="grid gap-4 xl:grid-cols-3">
        <article className="dashboard-panel rounded-lg border border-white/[0.08] p-4"><div className="flex items-center justify-between"><h2 className="text-sm font-semibold">{tr("Top Devices", "أفضل الأجهزة", "Meilleurs appareils")}</h2><Link to="/devices" className="text-[10px] text-white/70">{tr("View All", "عرض الكل", "Voir tout")}</Link></div><div className="mt-4 space-y-3">{devices.slice(0,5).map((device, index) => <div key={device.id}><div className="flex items-center justify-between text-[11px]"><span>{device.name}</span><span className="text-white/65">{device.status === "Busy" ? tr("In use", "مشغول", "Occupé") : tr("Available", "متاح", "Disponible")}</span></div><div className="mt-1.5 h-1 overflow-hidden rounded-full bg-white/[0.07]"><div className="h-full rounded-full bg-[#ef233c]" style={{width:`${Math.max(20, 92-index*15)}%`}}/></div></div>)}</div></article>
        <article className="dashboard-panel rounded-lg border border-white/[0.08] p-4"><div className="flex items-center justify-between"><h2 className="text-sm font-semibold">{tr("Active Alerts", "التنبيهات النشطة", "Alertes actives")}</h2><Wrench size={15} className="text-amber-300"/></div><div className="mt-4 space-y-2"><div className="rounded-md border border-amber-500/10 bg-amber-500/[0.05] p-3 text-[11px]"><p className="font-medium text-amber-300">{tr("Device monitoring active", "مراقبة الأجهزة مفعلة", "Surveillance active")}</p><p className="mt-1 text-white/70">{tr("Available devices are being tracked.", "يتم تتبع حالة الأجهزة المتاحة.", "Les appareils sont suivis.")}</p></div><div className="rounded-md border border-white/[0.06] bg-white/[0.018] p-3 text-[11px]"><p className="font-medium">{tr("Live sessions", "الجلسات المباشرة", "Sessions en direct")}</p><p className="mt-1 text-white/70">{sessions.length} {tr("currently active", "نشطة حاليًا", "actives actuellement")}</p></div></div></article>
        <article className="dashboard-panel rounded-lg border border-white/[0.08] p-4"><div className="flex items-center justify-between"><h2 className="text-sm font-semibold">{tr("Arena Summary", "ملخص القاعة", "Résumé de l’arène")}</h2><Timer size={15} className="text-purple-300"/></div><div className="mt-4 grid grid-cols-2 gap-3"><div className="rounded-md bg-white/[0.025] p-3"><p className="text-[10px] text-white/65">{tr("Average Duration", "متوسط المدة", "Durée moyenne")}</p><p className="mt-1 text-lg font-semibold">{average}m</p></div><div className="rounded-md bg-white/[0.025] p-3"><p className="text-[10px] text-white/65">{tr("Occupancy", "الإشغال", "Occupation")}</p><p className="mt-1 text-lg font-semibold">{occupancy}%</p></div></div></article>
      </section>
    </div>
  );
}
